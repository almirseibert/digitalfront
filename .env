# ==============================================================
# VARIÁVEIS DE AMBIENTE DO FRONTEND (React / Vite)
# ==============================================================
# Nota: Em projetos React usando Vite, as variáveis públicas
# devem sempre começar com o prefixo "VITE_"

# URL de conexão com o seu Backend (API)
# Durante o desenvolvimento no seu computador, deixe localhost:3000.
# Quando hospedar no aaPanel, mude para o domínio real (ex: https://api.digitalplus.com)
VITE_API_URL=https://sites-digitalplussback.oehpg2.easypanel.host/api

# Nome da Aplicação para aparecer em abas e títulos dinâmicos
VITE_APP_NAME="CRM digit@l plus+"